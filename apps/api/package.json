    "@canton-mvp/token-standard": "workspace:*",
    "@canton-mvp/validator-client": "workspace:*",
    "@canton-mvp/wallet-adapter": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/sensible": "^6.0.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.1.0",
    "jose": "^5.9.6",
