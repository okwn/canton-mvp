# Canton MVP API — Production environment template
# Operator responsibility: provision all secrets via secrets manager.
# Do NOT use .env files in production; inject at runtime.

NODE_ENV=production
PORT=8080

# REQUIRED in production
AUTH_JWT_SECRET=           # From secrets manager. Min 32 chars.
AUTH_BEARER_ENABLED=true

# REMOVE in production
# SEED_ADMIN_EXTERNAL_ID=

# Canton endpoints (TLS in production)
LEDGER_API_URL=
VALIDATOR_API_URL=
SCAN_API_URL=

# mTLS when Canton requires client certs
MTLS_CLIENT_CERT_PATH=
MTLS_CLIENT_KEY_PATH=
MTLS_CA_PATH=

# Rate limiting (recommended)
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW_MS=60000

# CORS (comma-separated allowed origins)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

LOG_LEVEL=info
