# Canton MVP API — Environment template
# Copy to .env and fill. NEVER commit .env.
# See docs/security-model.md and docs/production-hardening-checklist.md

# --- Required ---
NODE_ENV=development
PORT=8080

# --- Auth (production: required) ---
# JWT secret for signing/verification. Min 32 chars. Use secrets manager in production.
# AUTH_JWT_SECRET=

# Bearer mode: true = JWT or opaque token; false = disabled (dev only)
AUTH_BEARER_ENABLED=true

# --- Local dev shortcuts (DISABLE in production) ---
# externalId that gets admin role on first user create. Remove in production.
# SEED_ADMIN_EXTERNAL_ID=

# --- Canton / Ledger ---
# LEDGER_API_URL=
# VALIDATOR_API_URL=
# SCAN_API_URL=

# --- mTLS (production: when connecting to Canton with client certs) ---
# Paths to PEM files. Operator must provision.
# MTLS_CLIENT_CERT_PATH=
# MTLS_CLIENT_KEY_PATH=
# MTLS_CA_PATH=

# --- Rate limiting (production: enable) ---
# RATE_LIMIT_MAX=100
# RATE_LIMIT_TIME_WINDOW_MS=60000

# --- Logging ---
LOG_LEVEL=info
