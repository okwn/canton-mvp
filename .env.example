# Canton MVP — Environment template
# Copy to .env and adjust for your environment.

# -----------------------------------------------------------------------------
# Canton / Ledger
# -----------------------------------------------------------------------------
LEDGER_API_URL=http://canton.localhost:2975
VALIDATOR_API_URL=http://canton.localhost:2903
SCAN_API_URL=http://scan.localhost:4000

# -----------------------------------------------------------------------------
# Auth (dev: shared-secret; prod: OAuth2)
# -----------------------------------------------------------------------------
AUTH_MODE=shared-secret
AUTH_TOKEN=

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
PORT=8080
NODE_ENV=development

# CORS (production: restrict). Comma-separated origins, e.g. https://app.example.com
# CORS_ORIGINS=

# Rate limiting (production: enable)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_TIME_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Docker / LocalNet (when using Splice LocalNet)
# -----------------------------------------------------------------------------
# LOCALNET_DIR=docker/modules/localnet
